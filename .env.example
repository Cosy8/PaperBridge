# ============================================================
# PaperBridge — Environment Configuration
#
# Copy this file to .env and fill in real values before running.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All fields marked CHANGE_ME must be replaced before use.
# ============================================================

# PostgreSQL
POSTGRES_USER=paperbridge
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=paperbridge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full connection URL (used by api + processor services)
POSTGRES_URL=postgresql://paperbridge:CHANGE_ME@postgres/paperbridge

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_ARTICLES=raw-articles
KAFKA_TOPIC_PROCESSED=processed-articles
KAFKA_TOPIC_EMBEDDINGS=embeddings-ready

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=articles

# MinIO — replace with strong credentials
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_RAW=raw-html
MINIO_BUCKET_EMBEDDINGS=embeddings
MINIO_BUCKET_MODELS=models

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=paperbridge-embeddings

# API — generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=CHANGE_ME
API_CORS_ORIGINS=http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Scraper
SCHOLAR_USE_PROXY=false
TOR_PROXY_URL=socks5://tor:9050
MAX_SCRAPE_WORKERS=4
SCRAPE_DELAY_SECONDS=2

# FAISS
FAISS_INDEX_PATH=/data/faiss/articles.index
FAISS_DIMENSION=384

# Airflow — generate fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME
AIRFLOW_SECRET_KEY=CHANGE_ME

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=paperbridge
